---
interface Props {
  darkNav?: boolean;
}
const { darkNav = false } = Astro.props;
const pathname = Astro.url.pathname;

const links = [
  { href: '/about',    label: 'About' },
  { href: '/blog',     label: 'Blog' },
  { href: '/research', label: 'Research' },
  { href: '/projects', label: 'Projects' },
  { href: '/cv',       label: 'CV' },
];
---
<header
  id="site-nav"
  class={`fixed top-0 left-0 right-0 z-50 transition-all duration-500 ${darkNav ? 'bg-transparent' : 'bg-[#000500]/95 backdrop-blur-sm border-b border-[#6D5959]'}`}
>
  <nav class="max-w-6xl mx-auto px-8 h-14 flex items-center justify-between">
    <a href="/" class="font-mono text-xs tracking-[0.15em] uppercase text-[#D2E59E] hover:text-[#FE9000] transition-colors">
      DR
    </a>
    <div class="flex items-center gap-7">
      {links.map(link => (
        <a
          href={link.href}
          class={`font-mono text-[11px] tracking-[0.15em] uppercase transition-colors
            ${pathname.startsWith(link.href) ? 'text-[#FE9000]' : 'text-[#9FA0C3] hover:text-[#D2E59E]'}`}
        >
          {link.label}
        </a>
      ))}
      <span class="text-[#6D5959]">|</span>
      <a href="https://github.com/davidrourap" target="_blank" rel="noopener noreferrer"
         class="font-mono text-[11px] tracking-[0.1em] text-[#9FA0C3] hover:text-[#FE9000] transition-colors">GH</a>
      <a href="https://www.linkedin.com/in/davidrourap" target="_blank" rel="noopener noreferrer"
         class="font-mono text-[11px] tracking-[0.1em] text-[#9FA0C3] hover:text-[#FE9000] transition-colors">LI</a>
    </div>
  </nav>
</header>

<script>
  const nav = document.getElementById('site-nav');
  if (nav?.classList.contains('bg-transparent')) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 80) {
        nav.classList.remove('bg-transparent');
        nav.classList.add('bg-[#000500]/95', 'backdrop-blur-sm', 'border-b', 'border-[#6D5959]');
      } else {
        nav.classList.add('bg-transparent');
        nav.classList.remove('bg-[#000500]/95', 'backdrop-blur-sm', 'border-b', 'border-[#6D5959]');
      }
    }, { passive: true });
  }
</script>
