    <span class="font-mono text-[11px] text-[#9FA0C3] tracking-[0.12em] uppercase">
      © {year} David Roura Padrosa
    </span>
    <div class="flex gap-6">
      <a href="https://github.com/drou0302" target="_blank" rel="noopener noreferrer"
         class="font-mono text-[11px] text-[#9FA0C3] hover:text-[#FE9000] tracking-[0.12em] uppercase transition-colors">GitHub</a>
      <a href="https://www.linkedin.com/in/davidrourap" target="_blank" rel="noopener noreferrer"
         class="font-mono text-[11px] text-[#9FA0C3] hover:text-[#FE9000] tracking-[0.12em] uppercase transition-colors">LinkedIn</a>
      <a href="https://www.inseit.ch" target="_blank" rel="noopener noreferrer"
