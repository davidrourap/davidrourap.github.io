---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  darkNav?: boolean;
  image?: string;
}

const {
  title,
  description = 'David Roura Padrosa — Biochemist & Co-founder of inseit.ch',
  darkNav = false,
  image = '/images/photo.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://davidrourap.github.io');
const pageTitle = title === 'David Roura Padrosa' ? title : `${title} — David Roura Padrosa`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, 'https://davidrourap.github.io')} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, 'https://davidrourap.github.io')} />
  </head>
  <body class="bg-[#000500] text-[#D2E59E] min-h-screen flex flex-col">
    <Nav darkNav={darkNav} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
