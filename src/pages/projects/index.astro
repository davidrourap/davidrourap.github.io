---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects'))
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));

const statusLabel: Record<string, string> = {
  active: '● Active',
  completed: '✓ Completed',
  paused: '⏸ Paused',
};
const statusColor: Record<string, string> = {
  active: 'text-emerald-600',
  completed: 'text-stone-400',
  paused: 'text-amber-500',
};

const typeColors: Record<string, string> = {
  research: 'bg-emerald-50 text-emerald-700',
  startup: 'bg-blue-50 text-blue-700',
};
---
<BaseLayout title="Projects" description="Research and startup projects by David Rourap">
  <div class="max-w-3xl mx-auto px-6 pt-16 pb-20">
    <p class="text-sm font-medium text-blue-600 mb-3 uppercase tracking-wide">Projects</p>
    <h1 class="text-3xl font-bold text-stone-900 mb-2">Work</h1>
    <p class="text-stone-500 mb-10">Research projects, startups, and side endeavors.</p>

    {allProjects.length === 0 ? (
      <p class="text-stone-400 text-sm">No projects yet — add them via the CMS at <a href="/admin" class="text-blue-600 hover:underline">/admin</a>.</p>
    ) : (
      <div class="space-y-4">
        {allProjects.map(project => (
          <article class="bg-white border border-stone-200 rounded-lg p-5 hover:border-blue-200 hover:shadow-sm transition-all">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-2">
                  <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${typeColors[project.data.type]}`}>
                    {project.data.type}
                  </span>
                  <span class={`text-xs font-medium ${statusColor[project.data.status]}`}>
                    {statusLabel[project.data.status]}
                  </span>
                </div>
                <h2 class="font-medium text-stone-900 mb-1.5">
                  {project.data.link ? (
                    <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 transition-colors">
                      {project.data.title} ↗
                    </a>
                  ) : project.data.title}
                </h2>
                <p class="text-sm text-stone-500">{project.data.description}</p>
              </div>
              {project.data.year && (
                <span class="text-sm text-stone-400 shrink-0">{project.data.year}</span>
              )}
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
