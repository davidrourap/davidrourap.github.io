---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryAccent: Record<string, string> = {
  science:  'text-[#D2E59E]',
  startup:  'text-[#9FA0C3]',
  personal: 'text-[#FE9000]',
};
---

<style>
  .post-item[data-hidden] { display: none; }
</style>

<BaseLayout title="Blog" description="Writing on science, startups, and life — David Roura Padrosa">
  <div class="max-w-5xl mx-auto px-10 md:px-16 pt-28 pb-28">

    <!-- Header -->
    <div class="flex items-end justify-between gap-6 mb-20">
      <div>
        <div class="flex items-center gap-4 mb-5">
          <div class="h-px w-8 bg-[#FE9000] flex-shrink-0"></div>
          <span class="font-mono text-[9px] text-[#9FA0C3] tracking-[0.35em] uppercase">Field notes</span>
        </div>
        <h1 class="font-display font-semibold text-[#D2E59E] leading-[0.85] tracking-[-0.03em]"
            style="font-size:clamp(3.5rem,8vw,7rem);">
          Writing
        </h1>
      </div>
      <span class="font-mono text-[9px] text-[#6D5959] tracking-[0.2em] pb-2 hidden sm:block shrink-0">
        {allPosts.length} {allPosts.length === 1 ? 'entry' : 'entries'}
      </span>
    </div>

    <!-- Category filters — underline tab style -->
    <div class="flex items-center gap-0 mb-14 border-b border-[#6D5959]">
      {(['all', 'science', 'startup', 'personal'] as const).map((cat, i) => (
        <button
          data-filter={cat}
          class={`filter-btn font-mono text-[10px] tracking-[0.2em] uppercase px-5 py-3 border-b-2 -mb-px transition-colors duration-150
            ${i === 0
              ? 'border-b-[#FE9000] text-[#FE9000]'
              : 'border-b-transparent text-[#9FA0C3] hover:text-[#D2E59E]'}`}
        >
          {cat === 'all' ? 'All' : cat}
        </button>
      ))}
    </div>

    <!-- Post list -->
    {allPosts.length === 0 ? (
      <p class="font-serif text-[#9FA0C3] pt-8">No posts yet — check back soon.</p>
    ) : (
      <div id="posts">
        {allPosts.map((post, i) => {
          const slug = post.id.replace(/\.mdx?$/, '');
          const accent = categoryAccent[post.data.category];
          return (
            <article class="post-item border-t border-[#6D5959] last:border-b last:border-b-[#6D5959]"
                     data-cat={post.data.category}>
              <a href={`/blog/${slug}`}
                 class="group flex items-start gap-6 md:gap-10 py-10 pl-0 hover:pl-5 transition-all duration-200">
                <span class="font-mono text-[10px] text-[#6D5959] mt-2 shrink-0 tabular-nums w-5 group-hover:text-[#FE9000] transition-colors">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 mb-3">
                    <span class={`font-mono text-[9px] tracking-[0.15em] uppercase ${accent}`}>
                      {post.data.category}
                    </span>
                    <span class="font-mono text-[9px] text-[#6D5959]">·</span>
                    <span class="font-mono text-[9px] text-[#6D5959]">
                      {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </span>
                  </div>
                  <h2 class="font-display font-semibold text-[#D2E59E] group-hover:text-[#FE9000] transition-colors leading-[1.0] tracking-[-0.02em] mb-3"
                      style="font-size:clamp(1.5rem,3.5vw,2.2rem);">
                    {post.data.title}
                  </h2>
                  <p class="font-serif text-sm text-[#9FA0C3] leading-relaxed max-w-lg">
                    {post.data.description}
                  </p>
                </div>
                <span class="font-mono text-sm text-[#6D5959] mt-2.5 shrink-0 group-hover:text-[#FE9000] transition-colors">→</span>
              </a>
            </article>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLElement>('.filter-btn');
  const posts = document.querySelectorAll<HTMLElement>('.post-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      filterBtns.forEach(b => {
        b.classList.remove('border-b-[#FE9000]', 'text-[#FE9000]');
        b.classList.add('border-b-transparent', 'text-[#9FA0C3]');
      });
      btn.classList.remove('border-b-transparent', 'text-[#9FA0C3]');
      btn.classList.add('border-b-[#FE9000]', 'text-[#FE9000]');

      posts.forEach(post => {
        if (filter === 'all' || post.dataset.cat === filter) {
          post.removeAttribute('data-hidden');
        } else {
          post.setAttribute('data-hidden', '');
        }
      });
    });
  });
</script>
