---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const categoryAccent: Record<string, string> = {
  science:  'text-[#D2E59E]',
  startup:  'text-[#9FA0C3]',
  personal: 'text-[#FE9000]',
};
const accent = categoryAccent[post.data.category];
---

<BaseLayout title={post.data.title} description={post.data.description}>

  {post.data.image ? (
    <div>
      <!-- Full-bleed image header -->
      <div class="relative w-full overflow-hidden" style="height:clamp(320px,55vh,600px);">
        <img
          src={post.data.image}
          alt={post.data.title}
          class="absolute inset-0 w-full h-full object-cover"
          style="filter:saturate(0.45) brightness(0.6);"
        />
        <div class="absolute inset-0"
             style="background:linear-gradient(to bottom, rgba(0,5,0,0.25) 0%, rgba(0,5,0,0.55) 50%, #000500 100%);"></div>
        <div class="absolute inset-x-0 bottom-0 max-w-3xl mx-auto px-8 pb-12">
          <div class="flex items-center gap-4 mb-7">
            <a href="/blog" class="font-mono text-[9px] tracking-[0.2em] uppercase text-[#9FA0C3] hover:text-[#FE9000] transition-colors">← Writing</a>
            <div class="h-px w-5 bg-[#6D5959]"></div>
            <span class={`font-mono text-[9px] tracking-[0.15em] uppercase ${accent}`}>{post.data.category}</span>
          </div>
          <h1 class="font-display font-semibold text-[#D2E59E] leading-[0.88] tracking-[-0.025em] mb-5"
              style="font-size:clamp(2.2rem,5.5vw,4.5rem);">
            {post.data.title}
          </h1>
          <span class="font-mono text-[10px] text-[#9FA0C3] tracking-[0.1em]">
            {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
          </span>
        </div>
      </div>

      <article class="max-w-3xl mx-auto px-8 pt-10 pb-28">
        <p class="font-serif text-lg text-[#9FA0C3] leading-relaxed mb-12">{post.data.description}</p>
        <div class="h-px bg-[#6D5959] mb-14"></div>
        <div class="prose max-w-none
          prose-headings:font-display prose-headings:font-semibold prose-headings:tracking-tight prose-headings:text-[#D2E59E]
          prose-h2:text-[2rem] prose-h3:text-[1.5rem]
          prose-p:font-serif prose-p:text-[1.05rem] prose-p:leading-relaxed prose-p:text-[#9FA0C3]
          prose-a:text-[#FE9000] prose-a:no-underline hover:prose-a:underline
          prose-strong:text-[#D2E59E] prose-strong:font-semibold
          prose-blockquote:border-l-[#6D5959] prose-blockquote:not-italic prose-blockquote:text-[#9FA0C3]
          prose-code:font-mono prose-code:text-[0.85em] prose-code:bg-[#6D5959] prose-code:text-[#D2E59E] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-none
          prose-pre:bg-[#6D5959] prose-pre:rounded-none
          prose-hr:border-[#6D5959]
        ">
          <Content />
        </div>
        <div class="h-px bg-[#6D5959] mt-16 mb-10"></div>
        <a href="/blog" class="font-mono text-[9px] tracking-[0.25em] uppercase text-[#9FA0C3] hover:text-[#FE9000] transition-colors">← Back to Writing</a>
      </article>
    </div>
  ) : (
    <article class="max-w-3xl mx-auto px-8 pt-28 pb-28">

      <header class="mb-14">
        <div class="flex items-center gap-4 mb-10">
          <a href="/blog" class="font-mono text-[9px] tracking-[0.2em] uppercase text-[#9FA0C3] hover:text-[#FE9000] transition-colors">← Writing</a>
          <div class="flex-1 h-px bg-[#6D5959]"></div>
          <span class={`font-mono text-[9px] tracking-[0.15em] uppercase ${accent}`}>{post.data.category}</span>
        </div>

        <h1 class="font-display font-semibold text-[#D2E59E] leading-[0.88] tracking-[-0.025em] mb-7"
            style="font-size:clamp(2.5rem,6vw,5rem);">
          {post.data.title}
        </h1>

        <p class="font-serif text-lg text-[#9FA0C3] leading-relaxed mb-6">{post.data.description}</p>

        <span class="font-mono text-[10px] text-[#9FA0C3] tracking-[0.1em]">
          {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </span>
      </header>

      <div class="h-px bg-[#6D5959] mb-14"></div>

      <div class="prose max-w-none
        prose-headings:font-display prose-headings:font-semibold prose-headings:tracking-tight prose-headings:text-[#D2E59E]
        prose-h2:text-[2rem] prose-h3:text-[1.5rem]
        prose-p:font-serif prose-p:text-[1.05rem] prose-p:leading-relaxed prose-p:text-[#9FA0C3]
        prose-a:text-[#FE9000] prose-a:no-underline hover:prose-a:underline
        prose-strong:text-[#D2E59E] prose-strong:font-semibold
        prose-blockquote:border-l-[#6D5959] prose-blockquote:not-italic prose-blockquote:text-[#9FA0C3]
        prose-code:font-mono prose-code:text-[0.85em] prose-code:bg-[#6D5959] prose-code:text-[#D2E59E] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-none
        prose-pre:bg-[#6D5959] prose-pre:rounded-none
        prose-hr:border-[#6D5959]
      ">
        <Content />
      </div>

      <div class="h-px bg-[#6D5959] mt-16 mb-10"></div>
      <a href="/blog" class="font-mono text-[9px] tracking-[0.25em] uppercase text-[#9FA0C3] hover:text-[#FE9000] transition-colors">← Back to Writing</a>

    </article>
  )}

</BaseLayout>
