---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="CV" description="Curriculum Vitae of David Rourap — scientist and entrepreneur">
  <div class="max-w-3xl mx-auto px-6 pt-16 pb-20">
    <div class="flex items-center justify-between mb-8">
      <div>
        <p class="text-sm font-medium text-blue-600 mb-2 uppercase tracking-wide">Curriculum Vitae</p>
        <h1 class="text-3xl font-bold text-stone-900">David Rourap</h1>
      </div>
      <!-- Drop your CV PDF into /public/cv.pdf to enable this button -->
      <a
        href="/cv.pdf"
        download
        class="inline-flex items-center gap-2 bg-white border border-stone-200 text-stone-700 text-sm font-medium px-4 py-2 rounded-md hover:border-stone-300 hover:bg-stone-50 transition-colors"
      >
        ↓ Download PDF
      </a>
    </div>

    <div class="space-y-10 text-stone-700">

      <section>
        <h2 class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-4">Current Position</h2>
        <div class="space-y-3">
          <div class="flex justify-between items-start">
            <div>
              <p class="font-medium text-stone-900">CEO & Co-founder</p>
              <p class="text-sm text-stone-500"><a href="https://www.inseit.ch" target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 transition-colors">inseit.ch</a> · Switzerland</p>
            </div>
            <span class="text-sm text-stone-400 shrink-0 ml-4">20XX – present</span>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-4">Education</h2>
        <div class="space-y-4">
          <!-- Add your degrees here -->
          <div class="flex justify-between items-start">
            <div>
              <p class="font-medium text-stone-900">[Degree] in [Field]</p>
              <p class="text-sm text-stone-500">[University] · [Location]</p>
            </div>
            <span class="text-sm text-stone-400 shrink-0 ml-4">20XX – 20XX</span>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-4">Research & Experience</h2>
        <div class="space-y-4">
          <!-- Add your experience here -->
          <div class="flex justify-between items-start">
            <div>
              <p class="font-medium text-stone-900">[Role]</p>
              <p class="text-sm text-stone-500">[Institution / Company] · [Location]</p>
              <p class="text-sm text-stone-500 mt-1">[Brief description]</p>
            </div>
            <span class="text-sm text-stone-400 shrink-0 ml-4">20XX – 20XX</span>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-4">Publications</h2>
        <div class="space-y-3 text-sm">
          <!-- Add your publications here -->
          <p class="text-stone-500 italic">[Author(s)]. "[Title]." <em>[Journal]</em>, [Year]. <a href="#" class="text-blue-600 hover:underline">DOI ↗</a></p>
        </div>
      </section>

      <section>
        <h2 class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-4">Skills</h2>
        <div class="flex flex-wrap gap-2">
          {['[Skill 1]', '[Skill 2]', '[Skill 3]'].map(skill => (
            <span class="text-sm bg-stone-100 text-stone-700 px-3 py-1 rounded-full">{skill}</span>
          ))}
        </div>
      </section>

    </div>
  </div>
</BaseLayout>
