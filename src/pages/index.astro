---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const activeProjects = (await getCollection('projects', ({ data }) => data.status === 'active'))
  .slice(0, 4);

const categoryColors: Record<string, string> = {
  science:  'text-emerald-700 bg-emerald-50 border-emerald-200',
  startup:  'text-blue-700 bg-blue-50 border-blue-200',
  personal: 'text-amber-700 bg-amber-50 border-amber-200',
};
---
<BaseLayout title="David Roura Padrosa" darkNav={true}>

  <!-- ═══════════════════════════════════════════
       HERO — portrait + name, warm and human
  ═══════════════════════════════════════════ -->
  <section class="relative min-h-screen bg-[#100c09] flex flex-col md:flex-row overflow-hidden">

    <!-- Portrait — left half on desktop, top on mobile -->
    <div class="relative md:w-[45%] h-[55vw] md:h-auto overflow-hidden shrink-0">
      <img
        src="/images/photo.jpg"
        alt="David Roura Padrosa"
        class="w-full h-full object-cover object-top"
        style="filter: brightness(0.88) saturate(0.85);"
      />
      <!-- Gradient bleed into text side -->
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-[#100c09] hidden md:block pointer-events-none"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#100c09] via-transparent to-transparent md:hidden pointer-events-none"></div>
    </div>

    <!-- Name + intro — right side -->
    <div class="flex-1 flex flex-col justify-center px-10 md:px-14 lg:px-20 pb-16 pt-8 md:pt-28">

      <h1
        class="font-display font-semibold leading-[0.88] tracking-[-0.02em] text-[#f0ece3] animate-in"
        style="font-size: clamp(3.5rem, 8vw, 7rem); animation-delay: 0.15s"
      >
        David<br/>
        <span style="font-size: clamp(2.2rem, 5vw, 4.2rem); color: #b5ad9e;">Roura Padrosa</span>
      </h1>

      <div class="w-12 h-px bg-[#3a3028] mt-8 mb-8 animate-line" style="animation-delay: 0.35s"></div>

      <p
        class="font-serif text-[1.1rem] text-[#8a8278] leading-relaxed max-w-xs animate-in"
        style="animation-delay: 0.45s"
      >
        Biochemist building AI tools for enzyme immobilisation. Co-founder of
        <a href="https://www.inseit.ch" target="_blank" rel="noopener noreferrer"
           class="text-[#b5ad9e] hover:text-[#f0ece3] transition-colors underline underline-offset-2">inseit.ch</a>
        — based in Bern.
      </p>

      <div
        class="flex flex-wrap gap-3 mt-10 animate-in"
        style="animation-delay: 0.6s"
      >
        <a href="/about"
           class="font-mono text-[11px] tracking-[0.15em] uppercase text-[#f0ece3] border border-[#3a3028] px-5 py-2.5 hover:bg-[#f0ece3] hover:text-[#100c09] hover:border-[#f0ece3] transition-all duration-200">
          About me
        </a>
        <a href="/blog"
           class="font-mono text-[11px] tracking-[0.15em] uppercase text-[#6a6258] border border-[#2a2018] px-5 py-2.5 hover:border-[#3a3028] hover:text-[#b5ad9e] transition-all duration-200">
          Writing →
        </a>
        <a href="/cv"
           class="font-mono text-[11px] tracking-[0.15em] uppercase text-[#6a6258] border border-[#2a2018] px-5 py-2.5 hover:border-[#3a3028] hover:text-[#b5ad9e] transition-all duration-200">
          CV
        </a>
      </div>

      <!-- Social links -->
      <div
        class="flex gap-5 mt-10 animate-in"
        style="animation-delay: 0.75s"
      >
        <a href="https://github.com/drou0302" target="_blank" rel="noopener noreferrer"
           class="font-mono text-[10px] tracking-[0.15em] uppercase text-[#3a3028] hover:text-[#8a8278] transition-colors">GitHub ↗</a>
        <a href="https://www.linkedin.com/in/davidrourap" target="_blank" rel="noopener noreferrer"
           class="font-mono text-[10px] tracking-[0.15em] uppercase text-[#3a3028] hover:text-[#8a8278] transition-colors">LinkedIn ↗</a>
        <a href="https://orcid.org/0000-0001-6324-8722" target="_blank" rel="noopener noreferrer"
           class="font-mono text-[10px] tracking-[0.15em] uppercase text-[#3a3028] hover:text-[#8a8278] transition-colors">ORCID ↗</a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       CONTENT — warm cream
  ═══════════════════════════════════════════ -->
  <div class="bg-[#f4efe5]">

    <!-- Recent writing -->
    {recentPosts.length > 0 && (
      <section class="max-w-6xl mx-auto px-8 pt-20 pb-10">
        <div class="flex items-center gap-5 mb-12">
          <span class="font-mono text-[10px] text-[#aaa59f] tracking-[0.25em] uppercase shrink-0">Recent writing</span>
          <div class="flex-1 h-px bg-[#ddd8ce]"></div>
          <a href="/blog" class="font-mono text-[10px] text-[#2355b0] tracking-[0.15em] uppercase hover:underline shrink-0">All →</a>
        </div>

        <div class="space-y-px border border-[#ddd8ce]">
          {recentPosts.map((post, i) => {
            const slug = post.id.replace(/\.mdx?$/, '');
            return (
              <a href={`/blog/${slug}`} class="group block">
                <article class="flex items-center gap-6 px-6 py-5 bg-[#faf7f2] hover:bg-white transition-colors border-b border-[#ddd8ce] last:border-b-0">
                  <span class="font-mono text-[10px] text-[#ccc8c0] w-5 shrink-0">{String(i + 1).padStart(2, '0')}</span>
                  <div class="flex-1 min-w-0">
                    <h3 class="font-serif text-[1.05rem] font-semibold text-[#0f0e0c] group-hover:text-[#2355b0] transition-colors leading-snug">
                      {post.data.title}
                    </h3>
                    <p class="font-serif text-sm text-[#7a7570] mt-0.5 line-clamp-1">{post.data.description}</p>
                  </div>
                  <div class="shrink-0 flex items-center gap-4">
                    <span class={`font-mono text-[10px] tracking-[0.1em] uppercase px-2 py-0.5 border ${categoryColors[post.data.category]}`}>
                      {post.data.category}
                    </span>
                    <span class="font-mono text-[10px] text-[#aaa59f] hidden sm:block">
                      {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </span>
                  </div>
                </article>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Active projects -->
    {activeProjects.length > 0 && (
      <section class="max-w-6xl mx-auto px-8 pt-10 pb-20">
        <div class="flex items-center gap-5 mb-12">
          <span class="font-mono text-[10px] text-[#aaa59f] tracking-[0.25em] uppercase shrink-0">Active work</span>
          <div class="flex-1 h-px bg-[#ddd8ce]"></div>
          <a href="/projects" class="font-mono text-[10px] text-[#2355b0] tracking-[0.15em] uppercase hover:underline shrink-0">All →</a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {activeProjects.map(project => (
            <a
              href={project.data.link ?? '/projects'}
              target={project.data.link ? '_blank' : '_self'}
              rel="noopener noreferrer"
              class="group block"
            >
              <article class="bg-[#faf7f2] border border-[#ddd8ce] p-6 h-full hover:bg-white hover:border-[#c0b8ac] transition-all">
                <div class="flex items-center justify-between mb-3">
                  <span class={`font-mono text-[10px] tracking-[0.15em] uppercase px-2 py-0.5 border
                    ${project.data.type === 'startup' ? 'text-blue-700 bg-blue-50 border-blue-200' : 'text-emerald-700 bg-emerald-50 border-emerald-200'}`}>
                    {project.data.type}
                  </span>
                  {project.data.year && (
                    <span class="font-mono text-[10px] text-[#aaa59f]">{project.data.year}</span>
                  )}
                </div>
                <h3 class="font-display text-[1.35rem] font-semibold text-[#0f0e0c] group-hover:text-[#2355b0] transition-colors leading-tight mb-2">
                  {project.data.title}
                  {project.data.link && <span class="text-[#aaa59f] ml-1 text-base">↗</span>}
                </h3>
                <p class="font-serif text-sm text-[#7a7570] leading-relaxed">{project.data.description}</p>
              </article>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

</BaseLayout>
