---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About" description="About David Rourap — scientist, entrepreneur, founder of inseit.ch">
  <div class="max-w-3xl mx-auto px-6 pt-16 pb-20">
    <p class="text-sm font-medium text-blue-600 mb-3 uppercase tracking-wide">About</p>
    <h1 class="text-3xl font-bold text-stone-900 mb-8">David Rourap</h1>

    <div class="prose prose-stone max-w-none space-y-6 text-stone-700 leading-relaxed">
      <!-- Edit this section directly in the code, or convert to CMS-driven content later -->
      <p class="text-lg">
        I'm a scientist and entrepreneur based in Switzerland. I founded
        <a href="https://www.inseit.ch" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline">inseit.ch</a>,
        where we're working on [describe what inseit does].
      </p>

      <h2 class="text-lg font-semibold text-stone-900 pt-4">Background</h2>
      <p>
        [Your scientific background, training, research focus — a few sentences.]
      </p>

      <h2 class="text-lg font-semibold text-stone-900 pt-4">What I'm working on</h2>
      <p>
        [Current projects, research directions, what inseit is building.]
      </p>

      <h2 class="text-lg font-semibold text-stone-900 pt-4">Writing</h2>
      <p>
        I write about science, building a startup, and things I find interesting.
        <a href="/blog" class="text-blue-600 hover:underline">Read the blog →</a>
      </p>
    </div>

    <div class="mt-12 pt-8 border-t border-stone-200 flex gap-6">
      <a href="https://github.com/davidrourap" target="_blank" rel="noopener noreferrer" class="text-sm text-stone-500 hover:text-stone-900 transition-colors">GitHub ↗</a>
      <a href="https://www.linkedin.com/in/davidrourap" target="_blank" rel="noopener noreferrer" class="text-sm text-stone-500 hover:text-stone-900 transition-colors">LinkedIn ↗</a>
      <a href="https://www.inseit.ch" target="_blank" rel="noopener noreferrer" class="text-sm text-stone-500 hover:text-stone-900 transition-colors">inseit.ch ↗</a>
      <a href="/cv" class="text-sm text-stone-500 hover:text-stone-900 transition-colors">CV →</a>
    </div>
  </div>
</BaseLayout>
